text = "Permanent upgrades and decorations live here. Run-only cards and buffs stay inside the run."

[node name="StartRunButton" type="Button" parent="."]
layout_mode = 2
text = "Start New Run"

[node name="DecorateButton" type="Button" parent="."]
layout_mode = 2
text = "Decorate Cafe"

[node name="HubResetButton" type="Button" parent="."]
layout_mode = 2
text = "Reset Profile"

[node name="EquipmentSectionLabel" type="Label" parent="."]
layout_mode = 2
text = "Equipment"

[node name="EquipmentList" type="VBoxContainer" parent="."]
layout_mode = 2
