[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/ui/screens/hub_screen_view.gd" id="1_script"]
[ext_resource type="PackedScene" path="res://scenes/ui/components/choice_entry_view.tscn" id="2_choice_entry"]

[node name="HubScreenView" type="VBoxContainer"]
theme_override_constants/separation = 12
