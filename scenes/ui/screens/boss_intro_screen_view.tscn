[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/ui/screens/boss_intro_screen_view.gd" id="1_script"]
[ext_resource type="PackedScene" path="res://scenes/ui/components/hero_card_view.tscn" id="2_hero_card"]

[node name="BossIntroScreenView" type="VBoxContainer"]
theme_override_constants/separation = 12
