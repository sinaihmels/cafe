[gd_resource type="Resource" script_class="BuffDef" load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/modifiers/buff_def.gd" id="1_displaybuff"]
[ext_resource type="Script" path="res://scripts/effects/change_tips_effect.gd" id="2_tips"]

[sub_resource type="Resource" id="Resource_tips"]
script = ExtResource("2_tips")
effect_id = &"change_tips"
amount = 1

[resource]
script = ExtResource("1_displaybuff")
modifier_id = &"display_case_buff"
display_name = "Display Case"
description = "Passive modifier. Served customers leave 1 extra tip."
default_duration_turns = -1
max_stacks = 1
stackable = false
stat_modifiers = {}
on_customer_served_effects = [SubResource("Resource_tips")]
