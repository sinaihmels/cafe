[gd_resource type="Resource" script_class="DemoCustomerDef" load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/demo/data/customer_def.gd" id="1_customer"]
[ext_resource type="Script" path="res://scripts/demo/data/demand_rule.gd" id="2_demand"]

[sub_resource type="Resource" id="Demand_critic"]
script = ExtResource("2_demand")
required_tags = PackedStringArray("sweet", "baked")
optional_tags = PackedStringArray("chocolate", "cream")
min_quality = 2
score_weights = {
"good_threshold": 7,
"optional_weight": 1,
"perfect_threshold": 9,
"quality_weight": 1,
"required_weight": 2,
"success_threshold": 5,
"tip_basic": 3,
"tip_good": 4,
"tip_perfect": 6
}

[resource]
script = ExtResource("1_customer")
id = &"customer_critic_guest"
type = 2
display_name = "Neighborhood Critic"
patience = 5
stress_damage = 4
demands = [SubResource("Demand_critic")]
