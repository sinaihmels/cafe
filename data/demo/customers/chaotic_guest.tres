"good_threshold": 5,
"optional_weight": 1,
"perfect_threshold": 7,
"quality_weight": 1,
"required_weight": 2,
"success_threshold": 3,
"tip_basic": 2,
"tip_good": 4,
"tip_perfect": 5
}

[resource]
script = ExtResource("1_customer")
id = &"customer_chaotic_guest"
type = 3
display_name = "Chaotic Foodie"
patience = 4
stress_damage = 3
demands = [SubResource("Demand_chaotic")]
