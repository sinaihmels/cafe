[gd_resource type="Resource" script_class="StatusDef" load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/modifiers/status_def.gd" id="1_impatientstatus"]
[ext_resource type="Script" path="res://scripts/effects/change_patience_effect.gd" id="2_patience"]

[sub_resource type="Resource" id="Resource_patience"]
script = ExtResource("2_patience")
effect_id = &"change_patience"
amount = -1

[resource]
script = ExtResource("1_impatientstatus")
modifier_id = &"impatient_status"
display_name = "Impatient"
description = "Status. This customer loses an extra patience each turn."
default_duration_turns = -1
max_stacks = 1
stackable = false
stat_modifiers = {}
on_turn_end_effects = [SubResource("Resource_patience")]
