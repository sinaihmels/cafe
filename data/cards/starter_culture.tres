[gd_resource type="Resource" script_class="CardDef" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/cards/card_def.gd" id="1_culturecard"]
[ext_resource type="Script" path="res://scripts/effects/modify_item_effect.gd" id="2_cultureeffect"]
[ext_resource type="Texture2D" path="res://assets/demo/cards/card_coffee.png" id="3_art"]

[sub_resource type="Resource" id="Resource_culture"]
script = ExtResource("2_cultureeffect")
effect_id = &"modify_item"
required_source_tags = PackedStringArray("dough")
added_tags = PackedStringArray("tangy")
quality_delta = 1

[resource]
script = ExtResource("1_culturecard")
card_id = &"starter_culture"
display_name = "Feed Starter"
art = ExtResource("3_art")
energy_cost = 1
tags = PackedStringArray("modifier", "sourdough", "quality")
targeting_rules = "select_one_prep_item"
effects = [SubResource("Resource_culture")]
preview_text = "Deepen the dough's sourdough character and gain +1 quality."
