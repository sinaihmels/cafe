[gd_resource type="Resource" script_class="CardDef" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/cards/card_def.gd" id="1_proofcard"]
[ext_resource type="Script" path="res://scripts/effects/proof_item_effect.gd" id="2_proofeffect"]
[ext_resource type="Texture2D" path="res://assets/demo/cards/card_bake.png" id="3_art"]

[sub_resource type="Resource" id="Resource_proof"]
