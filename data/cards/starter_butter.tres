[gd_resource type="Resource" script_class="CardDef" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/cards/card_def.gd" id="1_card"]
[ext_resource type="Script" path="res://scripts/effects/add_pastry_tags_effect.gd" id="2_tags"]
[ext_resource type="Script" path="res://scripts/effects/set_pastry_flag_effect.gd" id="3_flag"]
[ext_resource type="Texture2D" path="res://assets/demo/cards/card_cream.png" id="4_art"]

[sub_resource type="Resource" id="Resource_butter_tags"]
script = ExtResource("2_tags")
tags_to_add = PackedStringArray("luxurious")

[sub_resource type="Resource" id="Resource_butter_flag"]
script = ExtResource("3_flag")
flag_name = &"butter_applied"
flag_value = true

[resource]
script = ExtResource("1_card")
card_id = &"starter_butter"
display_name = "Butter"
art = ExtResource("4_art")
energy_cost = 1
card_type = 0
targeting_rules = "none"
effects = [SubResource("Resource_butter_tags"), SubResource("Resource_butter_flag")]
preview_text = "Add butter to the active pastry."
