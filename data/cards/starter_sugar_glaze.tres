[gd_resource type="Resource" script_class="CardDef" load_steps=7 format=3]

[ext_resource type="Script" path="res://scripts/cards/card_def.gd" id="1_card"]
[ext_resource type="Script" path="res://scripts/effects/add_pastry_tags_effect.gd" id="2_tags"]
[ext_resource type="Script" path="res://scripts/effects/conditional_pastry_effect.gd" id="3_cond"]
[ext_resource type="Texture2D" path="res://assets/demo/cards/base_card.png" id="4_art"]

[sub_resource type="Resource" id="Resource_glaze_base"]
script = ExtResource("2_tags")
tags_to_add = PackedStringArray("sweet", "luxurious", "shiny", "pretty")

[sub_resource type="Resource" id="Resource_glaze_sticky"]
script = ExtResource("2_tags")
tags_to_add = PackedStringArray("sticky")

[sub_resource type="Resource" id="Resource_glaze_cond"]
script = ExtResource("3_cond")
forbidden_pastry_states = PackedStringArray("warm")
success_effects = [SubResource("Resource_glaze_sticky")]

[resource]
script = ExtResource("1_card")
card_id = &"starter_sugar_glaze"
display_name = "Sugar Glaze"
art = ExtResource("4_art")
energy_cost = 3
card_type = 1
targeting_rules = "select_one_plated_pastry"
effects = [SubResource("Resource_glaze_base"), SubResource("Resource_glaze_cond")]
preview_text = "Glaze your pastry. Warm pastries become beautiful; cold pastries become sticky."
