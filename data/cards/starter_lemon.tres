[gd_resource type="Resource" script_class="CardDef" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/cards/card_def.gd" id="1_card"]
[ext_resource type="Script" path="res://scripts/effects/add_pastry_tags_effect.gd" id="2_tags"]
[ext_resource type="Texture2D" path="res://assets/demo/cards/card_cinnamon_sugar.png" id="3_art"]

[sub_resource type="Resource" id="Resource_lemon"]
script = ExtResource("2_tags")
