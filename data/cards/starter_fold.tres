[gd_resource type="Resource" script_class="CardDef" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/cards/card_def.gd" id="1_foldcard"]
[ext_resource type="Script" path="res://scripts/effects/modify_item_effect.gd" id="2_foldeffect"]
[ext_resource type="Texture2D" path="res://assets/demo/cards/card_mix.png" id="3_art"]

[sub_resource type="Resource" id="Resource_fold"]
script = ExtResource("2_foldeffect")
effect_id = &"modify_item"
required_source_tags = PackedStringArray("dough")
added_tags = PackedStringArray("flaky")
quality_delta = 1

[resource]
script = ExtResource("1_foldcard")
card_id = &"starter_fold"
display_name = "Fold"
art = ExtResource("3_art")
energy_cost = 1
tags = PackedStringArray("modifier", "laminated", "quality")
targeting_rules = "select_one_prep_item"
effects = [SubResource("Resource_fold")]
preview_text = "Fold the dough for more layers and +1 quality."
