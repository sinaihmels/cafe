[gd_resource type="Resource" script_class="CardDef" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/cards/card_def.gd" id="1_starterserve"]
[ext_resource type="Script" path="res://scripts/effects/serve_item_effect.gd" id="2_serveeffect"]
[ext_resource type="Texture2D" path="res://assets/demo/cards/base_card.png" id="3_art"]

[sub_resource type="Resource" id="Resource_serve"]
script = ExtResource("2_serveeffect")
effect_id = &"serve_item"

[resource]
script = ExtResource("1_starterserve")
card_id = &"starter_serve"
display_name = "Serve"
art = ExtResource("3_art")
energy_cost = 1
tags = PackedStringArray("action", "service")
targeting_rules = "select_one_customer_and_one_table_item"
effects = [SubResource("Resource_serve")]
preview_text = "Serve 1 item from the table to 1 customer."
