[gd_resource type="Resource" script_class="CardDef" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/cards/card_def.gd" id="1_card"]
[ext_resource type="Script" path="res://scripts/effects/add_pastry_tags_effect.gd" id="2_tags"]
[ext_resource type="Texture2D" path="res://assets/demo/cards/card_chocolate.png" id="3_art"]

[sub_resource type="Resource" id="Resource_strawberry"]
script = ExtResource("2_tags")
tags_to_add = PackedStringArray("sweet", "fruity", "pretty")

[resource]
script = ExtResource("1_card")
card_id = &"starter_strawberry"
display_name = "Strawberry"
art = ExtResource("3_art")
energy_cost = 2
tags = PackedStringArray("ingredient")
targeting_rules = "none"
effects = [SubResource("Resource_strawberry")]
preview_text = "Add strawberries to the active pastry."
